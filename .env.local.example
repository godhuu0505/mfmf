# Supabase 接続情報 (.env.local にコピーして値を設定)
# Supabase ダッシュボード > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_ANON_KEY

# --- Google Drive 連携（Google ログイン / 写真保存）---
# 設定手順は docs/guides/google-drive-setup.md を参照。
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET:
#   Google Cloud で作成した OAuth クライアント（Supabase の Google プロバイダにも同じ値を設定）。
#   保存済み refresh token から Drive 用 access token を発行するためにサーバーで使う。
#   ★ NEXT_PUBLIC_ を付けない（クライアントに出さない）。Secret はリポジトリに置かない。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# TOKEN_ENC_KEY: refresh token を DB 保存する前にアプリ層で暗号化する鍵（任意長の長い乱数文字列）。
#   生成例: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   ★ 失うと保存済み連携を復号できなくなる。サーバー専用・リポジトリに置かない。
TOKEN_ENC_KEY=

# --- Sentry エラーモニタリング / Web Vitals（任意・サーバ側のみ） ---
# 未設定でもアプリは動く（Sentry SDK は no-op になる）。本番で有効化するときは
# Sentry プロジェクトを作成し、DSN を以下に設定する。設定手順は docs/guides/sentry.md。
# クライアント側 SDK はバンドル削減のため同梱していない（必要なら docs を参照）。
# Web Vitals（LCP/INP/CLS/FCP/TTFB）の p75 も同じ DSN で Sentry に送られる
# （/api/vitals → Trace Metrics。確認手順は docs/guides/sentry.md）。
SENTRY_DSN=
# tracesSampleRate（0〜1、未設定なら 0.1 = 10% を tracing）。
# SENTRY_TRACES_SAMPLE_RATE=
# 環境名（vercel preview/production を上書きしたい時）。
# SENTRY_ENVIRONMENT=
# Source map アップロード用（CI で設定する。ローカルでは不要）。
#   SENTRY_AUTH_TOKEN が設定されている場合だけ build 時にアップロードする。
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- 障害報告・機能要望フォームの Issue 化スクリプト (任意) ---
# アプリ本体は GitHub に何も送らない（公開リポに内容が漏れないようにするため）。
# 送信内容は Supabase の feedback テーブルに保存され、必要なときに
# `npm run feedback:issues` で個人情報・秘匿情報をマスクして GitHub Issue 化する。
# 以下はそのスクリプト用の値で、Web アプリ自体は使わない。
# 実行例: node --env-file=.env.local scripts/feedback-to-issues.mjs --dry-run
#
# FEEDBACK_USER_EMAIL / FEEDBACK_USER_PASSWORD:
#   投稿を読むための夫婦共用ログイン（RLS 経由で自分の投稿だけ取得。service_role は使わない）。
# GITHUB_TOKEN: Issues 書き込み権を持つ Fine-grained Personal Access Token。
# GITHUB_FEEDBACK_REPO: 登録先 owner/repo。★ 内容が漏れないよう必ず「非公開リポジトリ」を指定する。
FEEDBACK_USER_EMAIL=
FEEDBACK_USER_PASSWORD=
GITHUB_TOKEN=
GITHUB_FEEDBACK_REPO=
