# Supabase 接続情報 (.env.local にコピーして値を設定)
# Supabase ダッシュボード > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_ANON_KEY

# --- 障害報告・機能要望フォームの Issue 化スクリプト (任意) ---
# アプリ本体は GitHub に何も送らない（公開リポに内容が漏れないようにするため）。
# 送信内容は Supabase の feedback テーブルに保存され、必要なときに
# `npm run feedback:issues` で個人情報・秘匿情報をマスクして GitHub Issue 化する。
# 以下はそのスクリプト用の値で、Web アプリ自体は使わない。
# 実行例: node --env-file=.env.local scripts/feedback-to-issues.mjs --dry-run
#
# FEEDBACK_USER_EMAIL / FEEDBACK_USER_PASSWORD:
#   投稿を読むための夫婦共用ログイン（RLS 経由で自分の投稿だけ取得。service_role は使わない）。
# GITHUB_TOKEN: Issues 書き込み権を持つ Fine-grained Personal Access Token。
# GITHUB_FEEDBACK_REPO: 登録先 owner/repo。★ 内容が漏れないよう必ず「非公開リポジトリ」を指定する。
FEEDBACK_USER_EMAIL=
FEEDBACK_USER_PASSWORD=
GITHUB_TOKEN=
GITHUB_FEEDBACK_REPO=
